# Rust build output
/target/

# Local Rooterr configuration and secrets. Keep example/template files tracked.
/rooterr.toml
/rooterr.*.toml
!/rooterr.toml.example

# Local config mounted into containers or used during development.
/config/
/*.local.toml
/*.secret.toml
/*.secrets.toml

# Environment files often contain API keys.
/.env
/.env.*
!/.env.example
!/.env.*.example
